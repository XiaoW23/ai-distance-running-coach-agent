# ==========================================
# 1. 敏感信息与环境变量 (最高安全级别)
# ==========================================
.env
*.env
*.env.*
!.env.example

# ==========================================
# 2. 本地数据库与检查点缓存 (严禁提交)
# ==========================================
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
checkpoints.db
running_memory.db*

# ==========================================
# 3. 个人训练数据、测试图与录屏 (隔离文件夹)
# ==========================================
running_data/
test_media/
*.mp4
*.mov
# 如果你在根目录下还有散落的测试图片，可以临时屏蔽：
error*.jpg
test*.jpg
problem*.mp4
0630_*.png

# ==========================================
# 4. 课程文档、开发说明与临时草稿
# ==========================================
*.docx
*.pdf
# 屏蔽各种 AI 开发过程中的临时说明和旧代码片段
*implementation_plan.md
running_pace_calculator.txt
.deps_hash

# ==========================================
# 5. Python / Node 基础系统编译缓存
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ==========================================
# 6. 编辑器与操作系统配置文件
# ==========================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ==========================================
# 7. 向量数据库与本地 Embedding 缓存
# ==========================================
chroma_db/
*.bin
*.onnx